---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
---

<Layout title="Projects | Vivek Banzade" description="Projects built by Vivek Banzade.">
  <section class="projects-page section">
    <div class="section-head">
      <h1>Projects</h1>
    </div>

    <ul class="entry-list">
      {projects.map((project) => (
        <li class="entry-item">
          <a class="entry-title" href={project.link}>{project.name}</a>
          <p class="entry-desc">{project.description}</p>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .section {
    padding: 2.6rem 0;
    border-top: 1px solid var(--line);
  }

  .section-head h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 2.6rem);
  }

  .entry-list {
    list-style: none;
    margin: 1.1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }

  .entry-item {
    padding: 0.35rem 0 0.35rem 1rem;
    border-left: 1px solid var(--line);
  }

  .entry-title {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    display: inline-block;
    font-size: clamp(1.22rem, 2.1vw, 1.5rem);
  }

  .entry-title:hover {
    color: var(--accent);
  }

  .entry-desc {
    margin: 0.3rem 0 0;
    color: var(--muted);
    max-width: 72ch;
  }

  @media (max-width: 760px) {
    .section {
      padding: 2rem 0;
    }

    .entry-item {
      padding-left: 0.75rem;
    }
  }
</style>
